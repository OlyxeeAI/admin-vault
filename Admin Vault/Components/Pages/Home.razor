@page "/"
@using Admin_Vault.Client.Models
@using Admin_Vault.Client.Services
@inject IVaultDataService Data
@inject IJSRuntime JS

<PageTitle>Dashboard | Olyxee Vault</PageTitle>

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">

    <div class="bg-white border border-gray-200 rounded-xl p-5 shadow-sm flex flex-col justify-between min-h-[110px]">
        <div class="flex justify-between items-start">
            <p class="text-[11px] font-bold text-gray-500 uppercase tracking-wider">Total Credentials</p>
            <span class="text-gray-400"><i data-lucide="key-round" class="w-4 h-4"></i></span>
        </div>
        <div class="mt-2">
            <h3 class="text-2xl font-bold text-gray-900 leading-none">@stats.TotalCredentials</h3>
            <p class="text-[11px] text-emerald-600 font-medium mt-1">All Encrypted AES-256</p>
        </div>
    </div>

    <div class="bg-white border border-gray-200 rounded-xl p-5 shadow-sm flex flex-col justify-between min-h-[110px]">
        <div class="flex justify-between items-start">
            <p class="text-[11px] font-bold text-gray-500 uppercase tracking-wider">Projects</p>
            <span class="text-amber-500"><i data-lucide="folder" class="w-4 h-4"></i></span>
        </div>
        <div class="mt-2">
            <h3 class="text-2xl font-bold text-gray-900 leading-none">@stats.TotalProjects</h3>
            <p class="text-[11px] text-gray-500 mt-1">Organized workspaces</p>
        </div>
    </div>

    <div class="bg-white border border-gray-200 rounded-xl p-5 shadow-sm flex flex-col justify-between min-h-[110px]">
        <div class="flex justify-between items-start">
            <p class="text-[11px] font-bold text-gray-500 uppercase tracking-wider">Compliance Documents</p>
            <span class="text-gray-400"><i data-lucide="file-text" class="w-4 h-4"></i></span>
        </div>
        <div class="mt-2">
            <h3 class="text-2xl font-bold text-gray-900 leading-none">@stats.ComplianceDocuments</h3>
            <p class="text-[11px] text-gray-500 font-medium mt-1">Stored artifacts</p>
        </div>
    </div>

    <div class="bg-white border border-gray-200 rounded-xl p-5 shadow-sm flex flex-col justify-between min-h-[110px]">
        <div class="flex justify-between items-start">
            <p class="text-[11px] font-bold text-gray-500 uppercase tracking-wider">Audit Triggers (24H)</p>
            <span class="text-indigo-600"><i data-lucide="activity" class="w-4 h-4"></i></span>
        </div>
        <div class="mt-2">
            <h3 class="text-2xl font-bold text-gray-900 leading-none">@stats.AuditTriggers24h</h3>
            <p class="text-[11px] text-gray-500 mt-1">@stats.UnauthorizedAttempts24h Unauthorized attempts</p>
        </div>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

    <div class="lg:col-span-2 bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden flex flex-col justify-between">
        <div>
            <div class="p-6 border-b border-gray-100 flex justify-between items-center bg-gray-50/50">
                <div>
                    <h3 class="font-bold text-base text-gray-900">Secure Credentials Vault</h3>
                    <p class="text-xs text-gray-500">Sensitive variables and configuration data</p>
                </div>
                <a href="/credentials" class="text-xs font-semibold text-gray-500 hover:text-gray-900 transition-colors">Manage</a>
            </div>

            <div class="overflow-x-auto">
                <table class="w-full text-left text-xs whitespace-nowrap">
                    <thead class="bg-gray-50 text-gray-500 uppercase font-semibold tracking-wider border-b border-gray-200 text-[10px]">
                        <tr>
                            <th class="px-6 py-3.5">Service & Env</th>
                            <th class="px-6 py-3.5">Secret Key Value</th>
                            <th class="px-6 py-3.5">Owner / Role</th>
                            <th class="px-6 py-3.5">Status</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100 text-gray-700">
                        @if (recentCredentials.Count == 0)
                        {
                            <tr><td colspan="4" class="px-6 py-8 text-center text-gray-400">No credentials stored yet.</td></tr>
                        }
                        else
                        {
                            @foreach (var credential in recentCredentials)
                            {
                                <tr class="hover:bg-gray-50/80 transition-colors">
                                    <td class="px-6 py-4">
                                        <div class="font-bold text-gray-900">@credential.ServiceName</div>
                                        <div class="text-[10px] font-medium flex items-center gap-1 mt-0.5" style="color: @credential.EnvColor">
                                            <span class="w-1.5 h-1.5 rounded-full" style="background-color: @credential.BgColor"></span> @credential.Environment
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 font-mono text-gray-500 tracking-tight select-all">@credential.MaskedValue</td>
                                    <td class="px-6 py-4">
                                        <div class="font-medium text-gray-800">@credential.OwnerEmail</div>
                                        <div class="text-[10px] text-gray-400">@credential.Department</div>
                                    </td>
                                    <td class="px-6 py-4">
                                        <span class="bg-emerald-50 text-emerald-700 text-[10px] font-bold px-2 py-0.5 rounded-md border border-emerald-200">@credential.Status</span>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="h-2 bg-gray-100 border-t border-gray-200"></div>
    </div>

    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6 flex flex-col justify-between min-h-[380px]">
        <div>
            <div class="flex justify-between items-center mb-6">
                <div class="flex items-center gap-2">
                    <span class="w-2 h-2 rounded-full bg-rose-500 animate-pulse"></span>
                    <h3 class="font-bold text-sm text-gray-900">Real-Time Audit Trail</h3>
                </div>
                <a href="/audit-logs" class="text-xs font-semibold text-gray-500 hover:text-gray-900 transition-colors">View All Logs</a>
            </div>

            <div class="space-y-4">
                @if (recentLogs.Count == 0)
                {
                    <p class="text-xs text-gray-400">No audit events recorded yet.</p>
                }
                else
                {
                    @foreach (var log in recentLogs)
                    {
                        <div class="pl-4 border-l-2 @(log.Status == "SUCCESS" ? "border-indigo-500" : "border-rose-500") space-y-1">
                            <div class="flex justify-between items-center text-[11px]">
                                <span class="font-bold text-gray-900 tracking-wide">@log.Status</span>
                                <span class="text-gray-400 font-medium">@log.Timestamp.ToString("HH:mm")</span>
                            </div>
                            <p class="text-xs text-gray-600 leading-normal">@log.Action</p>
                            <p class="text-[10px] font-mono text-gray-400">@log.ActorEmail</p>
                        </div>
                    }
                }
            </div>
        </div>

        <div class="mt-6 p-3 bg-gray-50 border border-gray-200 rounded-xl flex items-center gap-3 text-gray-500 text-center justify-center">
            <i data-lucide="shield" class="w-4 h-4 text-gray-400 shrink-0"></i>
            <span class="text-[11px] font-medium tracking-tight">Logs are historically absolute and un-deletable.</span>
        </div>
    </div>
</div>

@code {
    private DashboardStats stats = new();
    private List<VaultCredential> recentCredentials = new();
    private List<AuditLog> recentLogs = new();

    protected override async Task OnInitializedAsync()
    {
        stats = await Data.GetDashboardStatsAsync();
        recentCredentials = (await Data.GetCredentialsAsync()).Take(5).ToList();
        recentLogs = (await Data.GetAuditLogsAsync(5)).ToList();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JS.InvokeVoidAsync("refreshTailwindAndIcons");
    }
}
