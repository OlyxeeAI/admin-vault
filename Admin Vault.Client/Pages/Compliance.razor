@page "/compliance"
@using Admin_Vault.Client.Models
@using Admin_Vault.Client.Services
@inject IVaultDataService Data
@inject IJSRuntime JS

<PageTitle>Documents & Compliance | Olyxee Vault</PageTitle>

<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
    <div>
        <h2 class="text-xl font-bold text-gray-900">Documents & Regulatory Audits</h2>
        <p class="text-xs text-gray-500">All documents across projects, with cryptographic proof of integrity.</p>
    </div>
    <a href="/projects" class="bg-gray-900 hover:bg-gray-800 text-white text-xs font-semibold px-4 py-2.5 rounded-lg shadow-sm transition-all flex items-center gap-2 self-start sm:self-auto">
        <i data-lucide="folder" class="w-3.5 h-3.5"></i> Manage by Project
    </a>
</div>

<div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
    <div class="p-6 border-b border-gray-100 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 bg-gray-50/50">
        <div>
            <h3 class="font-bold text-base text-gray-900">Regulatory Artifact Ledger</h3>
            <p class="text-xs text-gray-500">Validated compliance source files.</p>
        </div>
        <div class="relative w-full sm:w-72">
            <i data-lucide="search" class="w-3.5 h-3.5 absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"></i>
            <input @bind="searchTerm" @bind:event="oninput" placeholder="Search by file, project, type..." class="w-full bg-white border border-gray-200 text-xs pl-9 pr-3 py-2 rounded-lg focus:outline-none focus:border-gray-400 text-gray-800" />
        </div>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full text-left text-xs whitespace-nowrap">
            <thead class="bg-gray-50 text-gray-500 uppercase font-semibold tracking-wider border-b border-gray-200 text-[10px]">
                <tr>
                    <th class="px-6 py-3.5">Project</th>
                    <th class="px-6 py-3.5">Document File Parameters</th>
                    <th class="px-6 py-3.5">SHA-256 Checksum Signature</th>
                    <th class="px-6 py-3.5">Intake Timestamp / Actor</th>
                    <th class="px-6 py-3.5">Classification</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 text-gray-700">
                @if (FilteredDocuments.Count == 0)
                {
                    <tr><td colspan="5" class="px-6 py-8 text-center text-gray-400">No documents match. Upload documents from within a project.</td></tr>
                }
                else
                {
                    @foreach (var doc in FilteredDocuments)
                    {
                        <tr class="hover:bg-gray-50/50 transition-colors">
                            <td class="px-6 py-4">
                                @if (doc.Project != null)
                                {
                                    <a href="@($"/projects/{doc.ProjectId}")" class="inline-flex items-center gap-2 group">
                                        <span class="w-6 h-6 rounded-md text-white text-[10px] font-bold flex items-center justify-center shrink-0" style="background-color: @doc.Project.AccentColor">@doc.Project.Initials</span>
                                        <span class="font-semibold text-gray-800 group-hover:text-gray-950">@doc.Project.Name</span>
                                    </a>
                                }
                                else
                                {
                                    <span class="text-gray-400">&mdash;</span>
                                }
                            </td>
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-3">
                                    <span class="text-gray-400"><i data-lucide="file-text" class="w-5 h-5"></i></span>
                                    <div>
                                        <div class="font-bold text-gray-900">@doc.FileName</div>
                                        <div class="text-[10px] text-gray-400 mt-0.5">@doc.FileSizeString</div>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4 font-mono text-gray-500 text-[11px]">@doc.ShortChecksum</td>
                            <td class="px-6 py-4">
                                <div class="text-gray-800 font-medium">@doc.UploadedAt.ToString("yyyy-MM-dd HH:mm")</div>
                                <div class="text-[10px] text-gray-400">@doc.UploadedBy</div>
                            </td>
                            <td class="px-6 py-4">
                                <span class="bg-gray-100 text-gray-800 text-[10px] font-bold px-2 py-0.5 rounded-md border border-gray-200">
                                    @doc.Classification
                                </span>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private List<ComplianceDocument> Documents = new();
    private string searchTerm = string.Empty;

    private List<ComplianceDocument> FilteredDocuments =>
        string.IsNullOrWhiteSpace(searchTerm)
            ? Documents
            : Documents.Where(d =>
                (d.FileName?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (d.Project?.Name?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (d.Classification?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (d.UploadedBy?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false)
            ).ToList();

    protected override async Task OnInitializedAsync()
    {
        Documents = await Data.GetDocumentsAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JS.InvokeVoidAsync("refreshTailwindAndIcons");
    }
}
